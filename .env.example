# -----------------------------------------------------------------------------
# Backend: Cloudflare R2
# -----------------------------------------------------------------------------
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<YOUR_ACCESS_KEY>
R2_SECRET_KEY=<YOUR_SECRET_KEY>
R2_BUCKET=obsidian-media
R2_PUBLIC_URL=https://pub-<ID>.r2.dev

# -----------------------------------------------------------------------------
# Translation Providers (publish-time auto-translation)
# Keep keys only in `.env`. Never put secrets in config.yaml or markdown frontmatter.
# -----------------------------------------------------------------------------
ZAI_API_KEY=<YOUR_ZAI_API_KEY>
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
TRANSLATION_MODEL=glm-5

# -----------------------------------------------------------------------------
# Blog: Site metadata & comments
# Copy the blog-related values below into `blog/.env.local` when running the
# Next.js app locally. The root template is the single source of truth.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GISCUS_REPO=your-username/linkdinger
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=General

# -----------------------------------------------------------------------------
# Blog: Upstash Redis (views + analytics)
# Optional public aliases can stay blank unless you explicitly need them client-side.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://<your-upstash-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>
NEXT_PUBLIC_UPSTASH_REDIS_REST_URL=
NEXT_PUBLIC_UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Blog: Consultation & secure analytics ingest
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/<your-handle>/<your-event>
ANALYTICS_INGEST_TOKEN=<generate-a-long-random-secret>
