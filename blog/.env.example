# Giscus Comments Configuration
# Get these values from https://giscus.app after enabling Discussions on your repo

# Your GitHub repo (e.g., "yourusername/linkdinger")
NEXT_PUBLIC_GISCUS_REPO=your-username/linkdinger

# Repo ID from giscus.app
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxxxxxxxx

# Discussion Category ID from giscus.app
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxxxxxxxx

# Optional: Discussion category name (default: "General")
NEXT_PUBLIC_GISCUS_CATEGORY=General

# Site URL used for canonical links and sharing
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis (views + analytics)
UPSTASH_REDIS_REST_URL=https://<your-upstash-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# Optional public alias if you explicitly need it in the browser
NEXT_PUBLIC_UPSTASH_REDIS_REST_URL=
NEXT_PUBLIC_UPSTASH_REDIS_REST_TOKEN=

# Optional consultation booking URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/<your-handle>/<your-event>

# Secure server-to-server analytics ingestion for booked sessions / realized revenue
ANALYTICS_INGEST_TOKEN=<generate-a-long-random-secret>
